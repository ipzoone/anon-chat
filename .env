# Railway sets DATABASE_URL automatically once you attach a Postgres plugin.
# For local development, copy this file to .env and fill in your own values.

# DATABASE_URL=postgresql://user:password@localhost:5432/anonchat
PORT=3000
DATABASE_URL=postgresql://postgres:edynhPGmNABJKiiNPuhAdUJjLhfiFaPU@postgres-tjej.railway.internal:5432/railway
# DATABASE_URL=postgresql://postgres:edynhPGmNABJKiiNPuhAdUJjLhfiFaPU@reseau.proxy.rlwy.net:10546/railway

# Set to "false" to stop saving chat message text to the database (rooms/reports are always kept).
STORE_MESSAGES=true